<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Play Zone</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

<header class="navbar">
  <div class="logo">🎮 Play Zone</div>
  <nav>
    <a href="/">Home</a>

    <% if (user) { %>
      <span style="margin-right: 15px; color: white;">Welcome, <%= user.username %></span>
      <a href="/logout">Logout</a>
    <% } else { %>
      <a href="/login">Login</a>
    <% } %>
  </nav>
</header>

<section class="hero">

  <% if (user) { %>

    <h1>Welcome back, <%= user.username %></h1>
    <p>
      Ready to play? Pick a game below and try to beat your best score.
    </p>

    <div class="hero-buttons">
      <a href="#games" class="btn">Browse Games</a>
    </div>

  <% } else { %>

    <h1>Welcome to Play Zone</h1>
    <p>
      Play Zone is a fun browser gaming platform where you can create an account,
      log in, and enjoy quick games directly in your browser without downloading anything.
    </p>

    <div class="hero-buttons">
      <a href="/login" class="btn">Start Playing</a>
    </div>

  <% } %>

</section>

<section class="games-section" id="games">
  <h2>Available Games</h2>

  <div class="game-grid">

    <div class="game-card">
      <img src="/images/tictactoe.png" class="game-img">
      <h3>Tic Tac Toe</h3>
      <p>Classic 2-player game</p>
      <a href="/tictactoe" class="card-btn">Play</a>
    </div>

    <div class="game-card">
      <img src="/images/quiz.jpg" class="game-img">
      <h3>Quiz</h3>
      <p>Test your knowledge</p>
      <a href="/quiz" class="card-btn">Play</a>
    </div>

    <div class="game-card">
      <img src="/images/reaction.png" class="game-img">
      <h3>Reaction</h3>
      <p>Test your speed</p>
      <a href="/reaction" class="card-btn">Play</a>
    </div>

    <div class="game-card">
      <img src="/images/memory.png" class="game-img">
      <h3>Memory</h3>
      <p>Match the cards</p>
      <a href="/memory" class="card-btn">Play</a>
    </div>

    <div class="game-card">
      <img src="/images/math.jpg" class="game-img">
      <h3>Math Quiz</h3>
      <p>Solve problems fast</p>
      <a href="/mathquiz" class="card-btn">Play</a>
    </div>

    <div class="game-card">
      <img src="/images/timer.jpg" class="game-img">
      <h3>Timer Challenge</h3>
      <p>Beat the clock</p>
      <a href="/timerchallenge" class="card-btn">Play</a>
    </div>

    <div class="game-card">
      <img src="/images/wordscramble.jpg" class="game-img">
      <h3>Word Scramble</h3>
      <p>Unscramble words</p>
      <a href="/wordscramble" class="card-btn">Play</a>
    </div>

    <div class="game-card">
      <img src="/images/guess.jpg" class="game-img">
      <h3>Guess Number</h3>
      <p>Find the number</p>
      <a href="/guess" class="card-btn">Play</a>
    </div>

  </div>
</section>

<footer style="text-align:center; padding:20px; color:#94a3b8;">
  <p>© 2026 Play Zone. All rights reserved.</p>
</footer>

</body>
</html>